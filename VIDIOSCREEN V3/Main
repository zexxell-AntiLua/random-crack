local __real_require = require
local __real_getfenv = getfenv
local __real_setfenv = setfenv
local __real_typeof  = typeof or type

-- 1. Penyamaran Objek Hasil Require agar Mendukung Metamethod Komplit
local fakeParcel = {}
setmetatable(fakeParcel, {
    __index = function(t, k)
        -- Mengembalikan fungsi serbaguna yang fleksibel terhadap pemanggilan berantai
